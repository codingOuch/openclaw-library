{
  "name": "openclaw-library",
  "version": "1.0.0",
  "private": true,
  "description": "LAN panel for browsing and editing the local openclaw knowledge library.",
  "scripts": {
    "server": "node server.js",
    "dev": "concurrently -n api,ui -c cyan,magenta \"node server.js\" \"vite --host 0.0.0.0 --port 8788 --config react-ui/vite.config.ts\"",
    "build": "vite build --config react-ui/vite.config.ts",
    "start": "node server.js"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "bootstrap-icons": "^1.11.3",
    "concurrently": "^9.2.1",
    "express": "^5.1.0",
    "fast-glob": "^3.3.3",
    "framer-motion": "^12.23.24",
    "marked": "^16.4.1",
    "motion": "^12.23.24",
    "typescript": "^5.9.3",
    "vite": "^7.1.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1"
  },
  "engines": {
    "node": ">=18"
  }
}
